REM !SIMPLE LOOP PROGRAM
PUSH $I LOVE YOU
PUSH #10
PUSH #0
LBL !MAINLOOP
JE &ENDLOOP
SWAP #2
INC
SWAP #2
DUP #0
INT #1
POP
JMP &MAINLOOP
LBL !ENDLOOP
PUSH $EXIT COMMAND
INT #1
END

--

.rem SIMPLE LOOP PROGRAM
pushs I LOVE YOU
pushi 10
pushi 0
.lbl MAINLOOP
je ENDLOOP
swap 2
inc
swap 2
dup 0
int 1
pop
jmp MAINLOOP
.lbl ENDLOOP
pushs EXIT COMMAND
int 1
end